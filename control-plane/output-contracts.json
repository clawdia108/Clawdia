{
  "version": 2,
  "description": "Output layers. Internal reasoning can be rich; exposed outputs must be human, warm, and interesting to read. All user-facing messages MUST follow knowledge/TELEGRAM_STYLE_GUIDE.md.",
  "style_guide": "knowledge/TELEGRAM_STYLE_GUIDE.md",
  "contracts": {
    "internal_snapshot": {
      "visibility": "internal",
      "format": "markdown_or_json",
      "max_lines": 80,
      "allow_task_ids": true,
      "allow_agent_names": true,
      "allow_timestamps": true,
      "required_sections": [
        "status",
        "blockers",
        "next_step"
      ]
    },
    "handoff_packet": {
      "visibility": "internal",
      "format": "structured_markdown",
      "max_lines": 18,
      "allow_task_ids": true,
      "allow_agent_names": true,
      "allow_timestamps": true,
      "required_sections": [
        "objective",
        "done",
        "open_questions",
        "next_step",
        "artifacts"
      ]
    },
    "review_report": {
      "visibility": "internal",
      "format": "markdown",
      "max_lines": 40,
      "allow_task_ids": true,
      "allow_agent_names": true,
      "allow_timestamps": true,
      "required_sections": [
        "findings",
        "risks",
        "decision"
      ],
      "style": "findings_first"
    },
    "cron_digest": {
      "visibility": "internal",
      "format": "markdown",
      "max_lines": 12,
      "allow_task_ids": false,
      "allow_agent_names": false,
      "allow_timestamps": false,
      "required_sections": [
        "what_changed",
        "what_needs_attention"
      ],
      "style": "changed_items_only"
    },
    "urgent_alert": {
      "visibility": "user_facing",
      "format": "markdown",
      "max_lines": 4,
      "allow_task_ids": false,
      "allow_agent_names": false,
      "allow_timestamps": false,
      "required_sections": [
        "problem",
        "action"
      ],
      "style_rules": {
        "must_read": "knowledge/TELEGRAM_STYLE_GUIDE.md",
        "tone": "direct_colleague",
        "format": "emoji_headline_then_action",
        "example": "⚡ Mycroft (350K) — nereagují od pátku.\n\nZavolej přímo CEO, email nestačí.",
        "forbidden": ["eskalace", "urgentní", "vyžaduje pozornost", "doporučení"]
      }
    },
    "user_report": {
      "visibility": "user_facing",
      "format": "markdown",
      "template": "templates/user-report.md",
      "language": "cs",
      "max_lines": 15,
      "allow_task_ids": false,
      "allow_agent_names": false,
      "allow_timestamps": false,
      "required_sections": [
        "main_message",
        "need_from_you"
      ],
      "optional_sections": [
        "schedule",
        "numbers",
        "headsup"
      ],
      "style_rules": {
        "must_read": "knowledge/TELEGRAM_STYLE_GUIDE.md",
        "tone": "smart_colleague_over_coffee",
        "language": "czech_informal_professional",
        "numbers": "rounded_with_context",
        "deals": "by_company_name_never_ids",
        "always": ["say_why_not_just_what", "include_recommendation", "be_interesting"],
        "never": ["jargon", "corporate_speak", "raw_data_dumps", "nested_bullet_lists", "tables"],
        "forbidden_words": [
          "pipeline health", "eskalace", "optimalizace", "workflow",
          "reprioritizace", "guardy", "fallback", "validovat",
          "klíčová čísla", "co vyžaduje pozornost", "neudržitelné",
          "Top 3 priority", "KPI", "stakeholder", "deliverable",
          "action item", "sync", "alignment", "leverage", "scalable"
        ],
        "checklist_before_send": [
          "Would I enjoy reading this on my phone between meetings?",
          "Is there any jargon or robot-speak?",
          "Does it say WHY, not just WHAT?",
          "Is there a specific recommendation?",
          "Is it under 15 lines?",
          "Would I call this interesting reading?"
        ]
      }
    }
  }
}
