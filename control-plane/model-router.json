{
  "version": 4,
  "description": "Task-aware multi-model routing. Evaluated top-to-bottom, first match wins. v4: GPT-5.4 replaces GPT-5.2 as default frontier model (March 2026).",
  "selection_dimensions": [
    "task_type",
    "complexity",
    "risk_level",
    "output_visibility",
    "requires_tools",
    "requires_parallel_workers",
    "capabilities_required"
  ],
  "models": {
    "openai/gpt-5.4": {
      "provider": "openai",
      "context_window": 272000,
      "max_output_tokens": 128000,
      "cost_per_1k_input_usd": 0.0025,
      "cost_per_1k_output_usd": 0.015,
      "strengths": ["reasoning", "tool_use", "computer_use", "tool_search", "knowledge_work", "context_management"],
      "notes": "Released 2026-03-05. 33% fewer errors vs 5.2, native computer use, 1M context available on request."
    },
    "openai/gpt-5.2": {
      "provider": "openai",
      "context_window": 400000,
      "max_output_tokens": 128000,
      "cost_per_1k_input_usd": 0.00175,
      "cost_per_1k_output_usd": 0.014,
      "strengths": ["reasoning", "tool_use", "coding", "context_management"],
      "status": "legacy — replaced by gpt-5.4 for most tasks"
    },
    "openai/gpt-5.2-pro": {
      "provider": "openai",
      "context_window": 400000,
      "max_output_tokens": 128000,
      "cost_per_1k_input_usd": 0.021,
      "cost_per_1k_output_usd": 0.168,
      "strengths": ["hard_reasoning", "adjudication", "precision"]
    },
    "openai/gpt-5.2-codex": {
      "provider": "openai",
      "context_window": 400000,
      "max_output_tokens": 128000,
      "cost_per_1k_input_usd": 0.00175,
      "cost_per_1k_output_usd": 0.014,
      "strengths": ["long_horizon_coding", "agentic_coding", "tool_use"]
    },
    "openai/gpt-5-mini": {
      "provider": "openai",
      "context_window": 400000,
      "max_output_tokens": 128000,
      "cost_per_1k_input_usd": 0.00025,
      "cost_per_1k_output_usd": 0.002,
      "strengths": ["cost_efficiency", "structured_output", "fast_reasoning"]
    },
    "openai/gpt-5-nano": {
      "provider": "openai",
      "context_window": 400000,
      "max_output_tokens": 128000,
      "cost_per_1k_input_usd": 0.00005,
      "cost_per_1k_output_usd": 0.0004,
      "strengths": ["summarization", "classification", "high_throughput"]
    },
    "anthropic/claude-opus-4-6": {
      "provider": "anthropic",
      "context_window": 200000,
      "max_output_tokens": 32000,
      "cost_per_1k_input_usd": 0.015,
      "cost_per_1k_output_usd": 0.075,
      "strengths": ["parallel_research", "advanced_coding", "deep_reasoning"]
    },
    "anthropic/claude-sonnet-4-6": {
      "provider": "anthropic",
      "context_window": 200000,
      "max_output_tokens": 64000,
      "cost_per_1k_input_usd": 0.003,
      "cost_per_1k_output_usd": 0.015,
      "strengths": ["writing", "review", "balanced_reasoning"]
    },
    "anthropic/claude-3-5-haiku-latest": {
      "provider": "anthropic",
      "context_window": 200000,
      "max_output_tokens": 8192,
      "cost_per_1k_input_usd": 0.0008,
      "cost_per_1k_output_usd": 0.004,
      "strengths": ["fast_checks", "low_latency", "cheap_screening"]
    },
    "ollama/llama3.1:8b": {
      "provider": "ollama",
      "context_window": 128000,
      "max_output_tokens": 8192,
      "cost_per_1k_input_usd": 0,
      "cost_per_1k_output_usd": 0,
      "strengths": ["local", "privacy", "fallback", "classification", "triage"]
    }
  },
  "routing_rules": [
    {
      "id": "heartbeat",
      "description": "Periodic lightweight status checks",
      "match": {
        "task_type": ["heartbeat"]
      },
      "model": "ollama/llama3.1:8b",
      "fallback": null,
      "max_tokens": 512,
      "budget_tier": "free"
    },
    {
      "id": "heartbeat_low_cost",
      "description": "Periodic lightweight checks and simple classification.",
      "match": {
        "task_type": ["heartbeat"],
        "risk_level": ["low"]
      },
      "pattern": "deterministic_router",
      "lead_model": "anthropic/claude-3-5-haiku-latest",
      "fallbacks": ["ollama/llama3.1:8b"],
      "output_contract": "cron_digest",
      "reasoning_effort": "minimal",
      "budget_tier": "free"
    },
    {
      "id": "output_simplification",
      "description": "Postprocess agent output for human-friendly summaries",
      "match": {
        "task_type": ["simplify_output"]
      },
      "model": "ollama/llama3.1:8b",
      "fallback": "anthropic/claude-haiku-4-5",
      "max_tokens": 1024,
      "budget_tier": "free"
    },
    {
      "id": "user_digest_pipeline",
      "description": "Turn internal state into a short user-facing digest.",
      "match": {
        "task_type": ["user_digest", "simplify_output", "cron_report"],
        "output_visibility": ["user_facing"]
      },
      "pattern": "background_digest",
      "lead_model": "anthropic/claude-3-5-haiku-latest",
      "reviewer_model": "anthropic/claude-3-5-haiku-latest",
      "output_model": "anthropic/claude-3-5-haiku-latest",
      "fallbacks": ["anthropic/claude-3-5-haiku-latest", "ollama/llama3.1:8b"],
      "output_contract": "user_report",
      "reasoning_effort": "low",
      "budget_tier": "economy"
    },
    {
      "id": "knowledge_sync",
      "description": "Summarization, deduplication, archival, and state snapshots.",
      "match": {
        "agent": ["archivar"],
        "task_type": ["knowledge_sync", "archival", "state_snapshot"],
        "complexity": ["low", "medium"]
      },
      "pattern": "deterministic_router",
      "lead_model": "anthropic/claude-3-5-haiku-latest",
      "model": "ollama/llama3.1:8b",
      "fallback": "anthropic/claude-haiku-4-5",
      "fallbacks": ["openai/gpt-5-nano", "ollama/llama3.1:8b"],
      "output_contract": "internal_snapshot",
      "reasoning_effort": "low",
      "max_tokens": 4096,
      "budget_tier": "economy"
    },
    {
      "id": "planning_calendar",
      "description": "Calendar management, time blocking, daily planning.",
      "match": {
        "agent": ["planovac"],
        "task_type": ["daily_plan", "calendar_plan", "meeting_prep"],
        "complexity": ["low", "medium"]
      },
      "pattern": "deterministic_router",
      "lead_model": "anthropic/claude-3-5-haiku-latest",
      "model": "anthropic/claude-haiku-4-5",
      "fallback": "ollama/llama3.1:8b",
      "fallbacks": ["anthropic/claude-3-5-haiku-latest", "ollama/llama3.1:8b"],
      "output_contract": "internal_snapshot",
      "reasoning_effort": "low",
      "max_tokens": 2048,
      "budget_tier": "economy"
    },
    {
      "id": "crm_structured_analysis",
      "description": "Pipeline hygiene, CRM scoring, and structured non-writing analysis.",
      "match": {
        "agent": ["udrzbar"],
        "task_type": ["crm_audit", "crm_hygiene", "crm_status"],
        "complexity": ["low", "medium"],
        "capabilities_required": ["structured_data", "json"]
      },
      "pattern": "deterministic_router",
      "lead_model": "anthropic/claude-3-5-haiku-latest",
      "reviewer_model": "anthropic/claude-3-5-haiku-latest",
      "model": "anthropic/claude-haiku-4-5",
      "fallback": "ollama/llama3.1:8b",
      "fallbacks": ["ollama/llama3.1:8b"],
      "output_contract": "internal_snapshot",
      "reasoning_effort": "low",
      "max_tokens": 4096,
      "budget_tier": "economy"
    },
    {
      "id": "lead_scoring_classification",
      "description": "Lead scoring, classification, and structured scoring output.",
      "match": {
        "task_type": ["lead_scoring", "lead_classification", "score_update"],
        "capabilities_required": ["structured_data", "analysis"]
      },
      "pattern": "deterministic_router",
      "lead_model": "anthropic/claude-3-5-haiku-latest",
      "fallbacks": ["anthropic/claude-3-5-haiku-latest", "ollama/llama3.1:8b"],
      "output_contract": "scoring_result",
      "reasoning_effort": "low",
      "budget_tier": "economy"
    },
    {
      "id": "sentiment_and_frame_detection",
      "description": "Email/message sentiment analysis, frame detection, buying signal extraction.",
      "match": {
        "task_type": ["sentiment_analysis", "frame_detection", "signal_extraction"],
        "capabilities_required": ["analysis", "structured_data"]
      },
      "pattern": "deterministic_router",
      "lead_model": "anthropic/claude-3-5-haiku-latest",
      "fallbacks": ["anthropic/claude-3-5-haiku-latest"],
      "output_contract": "sentiment_result",
      "reasoning_effort": "low",
      "budget_tier": "economy"
    },
    {
      "id": "cadence_management",
      "description": "Cadence step selection, timing, and sequence management.",
      "match": {
        "task_type": ["cadence_step", "cadence_routing", "sequence_management"],
        "capabilities_required": ["structured_data"]
      },
      "pattern": "deterministic_router",
      "lead_model": "anthropic/claude-3-5-haiku-latest",
      "fallbacks": ["anthropic/claude-3-5-haiku-latest", "ollama/llama3.1:8b"],
      "output_contract": "cadence_action",
      "reasoning_effort": "low",
      "budget_tier": "economy"
    },
    {
      "id": "spin_question_generation",
      "description": "SPIN question generation and pre-call brief creation.",
      "match": {
        "task_type": ["spin_questions", "pre_call_brief", "discovery_prep"],
        "capabilities_required": ["writing", "analysis"]
      },
      "pattern": "reviewer_refiner",
      "lead_model": "anthropic/claude-sonnet-4-6",
      "reviewer_model": "anthropic/claude-3-5-haiku-latest",
      "fallbacks": ["anthropic/claude-sonnet-4-6"],
      "output_contract": "question_bank",
      "reasoning_effort": "medium",
      "budget_tier": "standard"
    },
    {
      "id": "pitch_and_proposal",
      "description": "Pitch deck generation, proposal writing, pricing strategy.",
      "match": {
        "task_type": ["pitch_generation", "proposal_writing", "pricing_strategy"],
        "capabilities_required": ["writing", "analysis", "tone_matching"]
      },
      "pattern": "reviewer_refiner",
      "lead_model": "anthropic/claude-sonnet-4-6",
      "reviewer_model": "anthropic/claude-sonnet-4-6",
      "fallbacks": ["anthropic/claude-sonnet-4-6"],
      "output_contract": "proposal_draft",
      "reasoning_effort": "high",
      "budget_tier": "standard"
    },
    {
      "id": "social_selling_content",
      "description": "LinkedIn content generation, social selling sequences.",
      "match": {
        "task_type": ["linkedin_content", "social_selling", "connection_request"],
        "capabilities_required": ["writing", "tone_matching"]
      },
      "pattern": "reviewer_refiner",
      "lead_model": "anthropic/claude-sonnet-4-6",
      "reviewer_model": "anthropic/claude-3-5-haiku-latest",
      "fallbacks": ["anthropic/claude-sonnet-4-6"],
      "output_contract": "social_content",
      "reasoning_effort": "medium",
      "budget_tier": "standard"
    },
    {
      "id": "writing_with_review",
      "description": "Drafting and user-visible writing with an explicit review pass.",
      "match": {
        "agent": ["strateg"],
        "capabilities_required": ["writing", "tone_matching", "web_search", "synthesis"]
      },
      "pattern": "reviewer_refiner",
      "lead_model": "anthropic/claude-sonnet-4-6",
      "reviewer_model": "anthropic/claude-3-5-haiku-latest",
      "output_model": "anthropic/claude-3-5-haiku-latest",
      "model": "anthropic/claude-sonnet-4-6",
      "fallback": "anthropic/claude-haiku-4-5",
      "fallbacks": ["anthropic/claude-sonnet-4-6"],
      "output_contract": "handoff_packet",
      "reasoning_effort": "medium",
      "max_tokens": 4096,
      "budget_tier": "standard"
    },
    {
      "id": "content_generation",
      "description": "Email drafts, reports, user-facing summaries",
      "match": {
        "agent": ["postak", "main"],
        "capabilities_required": ["writing", "tone_matching"]
      },
      "model": "anthropic/claude-sonnet-4-6",
      "fallback": "anthropic/claude-haiku-4-5",
      "max_tokens": 4096,
      "budget_tier": "standard"
    },
    {
      "id": "research_parallel",
      "description": "Breadth-first web research with a strong lead agent and cheaper subagents.",
      "match": {
        "agent": ["kontrolor"],
        "task_type": ["research", "market_scan", "competitor_scan"],
        "requires_parallel_workers": [true],
        "capabilities_required": ["validation", "comparison"]
      },
      "pattern": "orchestrator_worker",
      "lead_model": "anthropic/claude-opus-4-6",
      "worker_model": "anthropic/claude-sonnet-4-6",
      "aggregator_model": "anthropic/claude-sonnet-4-6",
      "output_model": "anthropic/claude-3-5-haiku-latest",
      "model": "anthropic/claude-sonnet-4-6",
      "fallback": "anthropic/claude-haiku-4-5",
      "fallbacks": ["openai/gpt-5.4", "anthropic/claude-sonnet-4-6"],
      "output_contract": "internal_snapshot",
      "reasoning_effort": "high",
      "max_parallel_workers": 4,
      "max_tokens": 4096,
      "budget_tier": "premium"
    },
    {
      "id": "code_change_long_horizon",
      "description": "Long-horizon coding or orchestration refactors with tool use.",
      "match": {
        "task_type": ["code_change", "control_plane_upgrade"],
        "complexity": ["high"],
        "requires_tools": [true]
      },
      "pattern": "orchestrator_worker",
      "lead_model": "anthropic/claude-sonnet-4-6",
      "reviewer_model": "anthropic/claude-sonnet-4-6",
      "output_model": "anthropic/claude-3-5-haiku-latest",
      "fallbacks": ["anthropic/claude-opus-4-6", "anthropic/claude-3-5-haiku-latest"],
      "output_contract": "review_report",
      "reasoning_effort": "high",
      "budget_tier": "premium"
    },
    {
      "id": "high_risk_adjudication",
      "description": "Critical reviews, arbitration, or risky decisions.",
      "match": {
        "risk_level": ["critical"]
      },
      "pattern": "reviewer_refiner",
      "lead_model": "anthropic/claude-opus-4-6",
      "reviewer_model": "anthropic/claude-opus-4-6",
      "output_model": "anthropic/claude-3-5-haiku-latest",
      "fallbacks": ["anthropic/claude-sonnet-4-6"],
      "output_contract": "review_report",
      "reasoning_effort": "xhigh",
      "background_mode_preferred": true,
      "budget_tier": "premium"
    },
    {
      "id": "orchestrator_heavy_default",
      "description": "Default route for complex orchestration or cross-domain synthesis.",
      "match": {
        "complexity": ["high"]
      },
      "pattern": "orchestrator_worker",
      "lead_model": "anthropic/claude-sonnet-4-6",
      "worker_model": "anthropic/claude-sonnet-4-6",
      "output_model": "anthropic/claude-3-5-haiku-latest",
      "model": "anthropic/claude-sonnet-4-6",
      "fallback": "anthropic/claude-haiku-4-5",
      "fallbacks": ["anthropic/claude-opus-4-6", "anthropic/claude-3-5-haiku-latest"],
      "output_contract": "internal_snapshot",
      "reasoning_effort": "high",
      "max_tokens": 8192,
      "budget_tier": "premium"
    }
  ],
  "budget_tiers": {
    "free": {
      "daily_limit_usd": null,
      "cost_per_call_usd": 0,
      "daily_limit": null,
      "preferred_models": ["ollama/llama3.1:8b", "anthropic/claude-3-5-haiku-latest"]
    },
    "economy": {
      "daily_limit_usd": 3,
      "cost_per_call_usd": 0.005,
      "daily_limit": 50,
      "preferred_models": ["anthropic/claude-3-5-haiku-latest", "ollama/llama3.1:8b"]
    },
    "standard": {
      "daily_limit_usd": 8,
      "cost_per_call_usd": 0.02,
      "daily_limit": 30,
      "preferred_models": ["anthropic/claude-sonnet-4-6", "anthropic/claude-3-5-haiku-latest"]
    },
    "premium": {
      "daily_limit_usd": 20,
      "cost_per_call_usd": 0.05,
      "daily_limit": 10,
      "preferred_models": ["anthropic/claude-opus-4-6", "anthropic/claude-sonnet-4-6"]
    }
  },
  "selection_logic": "first_match_wins",
  "default_rule": "orchestrator_heavy_default"
}
